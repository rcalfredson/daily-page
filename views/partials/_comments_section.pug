-
  const commentCount = Number(commentsTotal || 0);
  const initialCount = Array.isArray(comments) ? comments.length : 0;
  const topLevelCount = Number(commentsTopLevelTotal || initialCount);
  const currentCommentsSortDir = commentsSortDir === 'desc' ? 'desc' : 'asc';
  const currentUsername = user && user.username ? user.username : '';
  const currentProfilePath = currentUsername ? `/users/${encodeURIComponent(currentUsername)}` : '';
  const focusedThread = commentsFocusedThread || null;
  const focusedCommentId = commentsDeepLinkCommentId || '';
  const commentDateFormatter = new Intl.DateTimeFormat(uiLang || lang || 'en', {
    dateStyle: 'medium',
    timeStyle: 'short'
  });

mixin renderComment(comment, isReply)
  -
    const timestamp = new Date(comment.createdAt);
    const timestampIso = timestamp.toISOString();
    const timestampLabel = commentDateFormatter.format(timestamp);
    const isNestedReply = Boolean(isReply);
    const isOwnedByViewer = Boolean(comment.ownedByViewer);
  article.comment(
    class=[isNestedReply ? 'comment--reply' : null, focusedCommentId && String(comment._id) === String(focusedCommentId) ? 'comment--highlighted' : null]
    data-comment-id=comment._id
    data-parent-comment-id=comment.parentCommentId || ''
    data-owned-by-viewer=isOwnedByViewer ? 'true' : 'false'
    id=comment._id ? `comment-${comment._id}` : null
  )
    header.comment__meta
      span.comment__author
        span.comment__byline= `${t('blockView.comments.by')} `
        if comment.authorProfilePath
          a.comment__username.user-profile-link(href=uiPath(comment.authorProfilePath))= comment.authorUsername
        else
          span.comment__username= comment.authorUsername || t('blockView.comments.unknownAuthor')
      .comment__meta-actions
        time.comment__time(datetime=timestampIso)= timestampLabel
        if comment.editedAt
          span.comment__edited= t('blockView.comments.manage.edited')
        if !isNestedReply
          button.comment__reply-button(
            type="button"
            data-comment-reply
            data-comment-id=comment._id
          )= t('blockView.comments.reply.action')
        if isOwnedByViewer
          button.comment__edit-button(
            type="button"
            data-comment-edit
            data-comment-id=comment._id
          )= t('blockView.comments.manage.editAction')
          button.comment__delete-button(
            type="button"
            data-comment-delete
            data-comment-id=comment._id
          )= t('blockView.comments.manage.deleteAction')
        button.comment__report-button(
          type="button"
          data-comment-report
          data-comment-id=comment._id
        )= t('blockView.comments.report.action')
    .comment__body
      p= comment.body
    if isOwnedByViewer
      form.comment-edit-form.hidden(
        data-comment-edit-form
        data-comment-id=comment._id
      )
        label.sr-only(for=`edit-body-${comment._id}`)= t('blockView.comments.manage.edit.label')
        textarea.comment-edit-form__input(
          id=`edit-body-${comment._id}`
          name="body"
          rows="4"
          maxlength="1500"
          required
          data-comment-edit-input
        )= comment.body
        .comment-edit-form__actions
          button.comment-edit-form__submit(
            type="submit"
            data-comment-edit-submit
          )= t('blockView.comments.manage.edit.save')
          button.comment-edit-form__cancel(
            type="button"
            data-comment-edit-cancel
          )= t('blockView.comments.manage.edit.cancel')
        p.comment-edit-form__status.hidden(
          role="status"
          aria-live="polite"
          data-comment-edit-status
        )
    if !isNestedReply && user && user.id && commentComposerCanSubmit
      form.comment-reply-form.hidden(
        data-comment-reply-form
        data-parent-comment-id=comment._id
      )
        label.sr-only(for=`reply-body-${comment._id}`)= t('blockView.comments.reply.label')
        textarea.comment-reply-form__input(
          id=`reply-body-${comment._id}`
          name="body"
          rows="3"
          maxlength="1500"
          required
          placeholder=t('blockView.comments.reply.placeholder')
          data-comment-reply-input
        )
        .comment-reply-form__actions
          button.comment-reply-form__submit(
            type="submit"
            data-comment-reply-submit
          )= t('blockView.comments.reply.submit')
          button.comment-reply-form__cancel(
            type="button"
            data-comment-reply-cancel
          )= t('blockView.comments.reply.cancel')
        p.comment-reply-form__status.hidden(
          role="status"
          aria-live="polite"
          data-comment-reply-status
        )

section.comments-section(
  id=`comments-${block._id}`
  aria-labelledby="comments-heading"
  data-comments-section
  data-block-id=block._id
  data-api-endpoint=uiPath(`/api/v1/comments/${block._id}`)
  data-initial-count=initialCount
  data-total-count=commentCount
  data-thread-total-count=topLevelCount
  data-page-size=commentsLimit || 20
  data-sort-dir=currentCommentsSortDir
  data-load-more-label=t('blockView.comments.loadMore')
  data-loading-label=t('blockView.comments.loading')
  data-load-error-label=t('blockView.comments.loadError')
  data-by-label=t('blockView.comments.by')
  data-unknown-author-label=t('blockView.comments.unknownAuthor')
  data-count-label-template=t('blockView.comments.count', { count: '__COUNT__' })
  data-empty-label=t('blockView.comments.empty')
  data-submit-label=t('blockView.comments.composer.submit')
  data-submitting-label=t('blockView.comments.composer.submitting')
  data-submit-success-label=t('blockView.comments.composer.success')
  data-submit-error-label=t('blockView.comments.composer.error')
  data-verify-prompt-label=t('blockView.comments.composer.verifyPrompt')
  data-report-label=t('blockView.comments.report.action')
  data-reporting-label=t('blockView.comments.report.pending')
  data-report-success-label=t('blockView.comments.report.success')
  data-report-error-label=t('blockView.comments.report.error')
  data-report-own-error-label=t('blockView.comments.report.ownError')
  data-report-hidden-label=t('blockView.comments.report.hidden')
  data-report-reported-label=t('blockView.comments.report.reported')
  data-reply-label=t('blockView.comments.reply.action')
  data-reply-cancel-label=t('blockView.comments.reply.cancel')
  data-reply-submit-label=t('blockView.comments.reply.submit')
  data-reply-submitting-label=t('blockView.comments.reply.submitting')
  data-reply-success-label=t('blockView.comments.reply.success')
  data-reply-error-label=t('blockView.comments.reply.error')
  data-reply-placeholder=t('blockView.comments.reply.placeholder')
  data-reply-login-label=t('blockView.comments.reply.loginPrompt')
  data-comment-edited-label=t('blockView.comments.manage.edited')
  data-edit-label=t('blockView.comments.manage.editAction')
  data-edit-field-label=t('blockView.comments.manage.edit.label')
  data-delete-label=t('blockView.comments.manage.deleteAction')
  data-edit-submit-label=t('blockView.comments.manage.edit.save')
  data-edit-submitting-label=t('blockView.comments.manage.edit.saving')
  data-edit-cancel-label=t('blockView.comments.manage.edit.cancel')
  data-edit-success-label=t('blockView.comments.manage.edit.success')
  data-edit-error-label=t('blockView.comments.manage.edit.error')
  data-edit-forbidden-label=t('blockView.comments.manage.forbidden')
  data-delete-confirm-label=t('blockView.comments.manage.deleteConfirm')
  data-delete-success-label=t('blockView.comments.manage.deleteSuccess')
  data-delete-error-label=t('blockView.comments.manage.deleteError')
  data-current-username=currentUsername
  data-current-profile-path=currentProfilePath
  data-can-reply=commentComposerCanSubmit ? 'true' : 'false'
  data-deep-link-status=commentsDeepLinkStatus || 'idle'
  data-deep-link-comment-id=focusedCommentId
  data-deep-link-unavailable-label=t('blockView.comments.deepLink.unavailable')
)
  .comments-section__header
    .comments-section__header-main
      h2#comments-heading.comments-section__title= t('blockView.comments.heading')
      p.comments-section__count(data-comments-count)= t('blockView.comments.count', { count: commentCount })
    if commentCount > 0
      .comments-section__sort
        label.comments-section__sort-label.sr-only(for=`comments-sort-${block._id}`)= t('blockView.comments.sort.label')
        select.comments-section__sort-select(
          id=`comments-sort-${block._id}`
          data-comments-sort
          aria-label=t('blockView.comments.sort.label')
        )
          option(value='asc' selected=currentCommentsSortDir === 'asc')= t('blockView.comments.sort.oldestFirst')
          option(value='desc' selected=currentCommentsSortDir === 'desc')= t('blockView.comments.sort.newestFirst')

  .comments-composer
    if user && user.id
      if commentComposerCanSubmit
        form.comments-composer__form(data-comments-form)
          label.sr-only(for=`comment-body-${block._id}`)= t('blockView.comments.composer.label')
          textarea.comments-composer__input(
            id=`comment-body-${block._id}`
            name="body"
            rows="4"
            maxlength="1500"
            required
            placeholder=t('blockView.comments.composer.placeholder')
            data-comments-input
          )
          .comments-composer__actions
            button.comments-composer__submit(
              type="submit"
              data-comments-submit
            )= t('blockView.comments.composer.submit')
          p.comments-composer__status.hidden(
            role="status"
            aria-live="polite"
            data-comments-form-status
          )
      else
        .comments-composer__gate.comments-composer__gate--warning
          p.comments-composer__gate-text= t('blockView.comments.composer.verifyPrompt')
          a.comments-composer__gate-link(href=uiPath('/verify-email'))= t('blockView.comments.composer.verifyCta')
    else
      .comments-composer__gate
        p.comments-composer__gate-text= t('blockView.comments.composer.loginPrompt')
        button.comments-composer__gate-button(
          type="button"
          data-comments-login
        )= t('blockView.comments.composer.loginCta')

  p.comments-section__empty(
    class=commentCount === 0 ? null : 'hidden'
    data-comments-empty
  )= t('blockView.comments.empty')

  if commentsDeepLinkStatus === 'unavailable'
    p.comments-section__deep-link-status(
      role='status'
      aria-live='polite'
    )= t('blockView.comments.deepLink.unavailable')

  if focusedThread
    p.comments-section__focus-note= t('blockView.comments.deepLink.focused')
    ol.comments-list.comments-list--focused(data-comments-focused-list)
      li.comments-list__item(data-comments-focused-thread='true')
        +renderComment(focusedThread, false)
        if Array.isArray(focusedThread.replies) && focusedThread.replies.length
          ol.comments-list__replies
            each reply in focusedThread.replies
              li.comments-list__reply-item
                +renderComment(reply, true)

  ol.comments-list(
    class=commentCount === 0 ? 'hidden' : null
    data-comments-list
  )
    each comment in comments
      li.comments-list__item
        +renderComment(comment, false)
        if Array.isArray(comment.replies) && comment.replies.length
          ol.comments-list__replies
            each reply in comment.replies
              li.comments-list__reply-item
                +renderComment(reply, true)

  if commentsHasMore
    .comments-section__actions
      button.comments-section__load-more(
        type="button"
        data-comments-load-more
      )= t('blockView.comments.loadMore')
  p.comments-section__load-error.hidden(
    role="status"
    aria-live="polite"
    data-comments-load-error
  )
