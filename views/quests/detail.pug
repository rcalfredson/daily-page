extends ../layout

include ../partials/_quest_badge

block nav
  include ../navLinks

block append head
  link(rel='stylesheet' href='/css/quests.css')
  link(rel='stylesheet' href='/css/pagination.css')

block append scripts
  script(src='/js/quest-contributor.js')
  script(src='/js/quest-tabs.js')

block content
  main.quests-page.quest-detail
    nav.quest-breadcrumb(aria-label=t('quests.detail.breadcrumbLabel'))
      a(href=uiPath('/quests'))= t('quests.detail.allQuests')
      span(aria-hidden='true') /
      span= quest.displayName

    header.quest-detail__hero
      if quest.badgeAssetPath
        img.quest-badge.quest-badge--large(src=quest.badgeAssetPath alt=t('quests.badge.alt', { questName: quest.displayName }))
      .quest-detail__intro
        .quest-detail__status
          span.quest-status(class=`quest-status--${quest.status}`)= t(`quests.status.${quest.status}`)
          span.quest-type= t(`quests.type.${quest.type}`)
        h1= quest.displayName
        if administrator
          p.quest-administrator
            | #{t('quests.detail.administeredBy')} 
            a(href=uiPath(`/users/${encodeURIComponent(administrator.username)}`))= administrator.username

    .quest-progress.quest-progress--hero
      .quest-progress__labels
        span= t('quests.progress.label')
        strong= t('quests.progress.count', { completed: progress.completedCount, target: progress.targetCount })
      progress.quest-progress__bar(value=progress.displayRatio max='1')
      span.quest-progress__percent= t('quests.progress.percent', { percent: Math.round(progress.displayRatio * 100) })

    .quest-detail__copy
      if descriptionHTML
        section.quest-copy-card
          h2= t('quests.detail.aboutHeading')
          .quest-rich-text!= descriptionHTML
      if instructionsHTML
        details.quest-copy-card.quest-instructions
          summary= t('quests.detail.instructionsHeading')
          .quest-rich-text!= instructionsHTML

    section#quest-contributions.quest-contributor-panel(
      data-quest-contributor
      data-quest-id=quest._id
      data-error-message=t('quests.contribute.errors.generic')
      data-block-ineligible-message=t('quests.contribute.errors.blockIneligible')
      data-item-unavailable-message=t('quests.contribute.errors.itemUnavailable')
      data-confirm-withdraw=t('quests.contribute.confirmWithdraw')
    )
      .quest-section-heading
        div
          p.quests-eyebrow= t('quests.contribute.eyebrow')
          h2= t(user && (mySubmissionTotal || mySubmissions.length) ? 'quests.contribute.mineHeading' : 'quests.contribute.heading')
        if canReviewQuest
          a.quest-button.quest-button--secondary(href=uiPath(`/quests/review?questId=${encodeURIComponent(quest._id)}`))= t('quests.review.openPanel')
      if !user
        p= t('quests.contribute.signInPrompt')
        a.quest-button(href=uiPath('/login'))= t('quests.contribute.signIn')
      else
        if canContribute && quest.type === 'count'
          p= t('quests.contribute.countPrompt')
          a.quest-button(href=uiPath(`/rooms/${quest.defaultRoomId}/blocks/new?questId=${encodeURIComponent(quest._id)}`))= t('quests.contribute.createPost')
        else if canContribute && quest.type === 'set' && !mySubmissionTotal && !mySubmissions.length
          p= t('quests.contribute.setPrompt')
          a.quest-button(href=uiPath(`/quests/${quest.slug}?view=items&state=available#quest-sections`))= t('quests.contribute.browseItems')
        else if !canContribute && !mySubmissionTotal && !mySubmissions.length
          p= t('quests.contribute.closed')

        if mySubmissions.length
          ul.quest-submission-list
            each submission in mySubmissions
              li.quest-submission-card(
                id=`quest-submission-${submission.id}`
                class=highlightedSubmissionId === submission.id ? 'quest-submission-card--highlighted' : ''
              )
                .quest-submission-card__heading
                  strong= submission.item ? submission.item.label : (submission.block ? submission.block.title : quest.displayName)
                  span.quest-item-state(class=`quest-item-state--${submission.status}`)= t(`quests.contribute.status.${submission.status}`)
                if submission.block
                  a(href=uiPath(`/rooms/${submission.block.roomId}/blocks/${submission.block.id}`))= submission.block.title
                - const latestComment = [...(submission.reviewHistory || [])].reverse().find(event => event.comment)
                if latestComment
                  p.quest-review-comment= latestComment.comment
                .quest-submission-actions
                  if submission.block && (submission.status === 'draft' || submission.status === 'changes-requested')
                    a.quest-button.quest-button--secondary(href=uiPath(`/rooms/${submission.block.roomId}/blocks/${submission.block.id}/edit`))= t('quests.contribute.editPost')
                  if submission.status === 'draft'
                    button.quest-button(type='button' data-quest-action='submit' data-submission-id=submission.id)= t('quests.contribute.requestReview')
                    button.quest-button.quest-button--secondary(type='button' data-quest-action='withdraw' data-submission-id=submission.id)= t('quests.contribute.withdraw')
                  else if submission.status === 'pending'
                    button.quest-button.quest-button--secondary(type='button' data-quest-action='withdraw' data-submission-id=submission.id)= t('quests.contribute.withdraw')
                  else if submission.status === 'changes-requested'
                    button.quest-button(type='button' data-quest-action='reopen' data-submission-id=submission.id)= t('quests.contribute.resumeEditing')
                    button.quest-button.quest-button--secondary(type='button' data-quest-action='withdraw' data-submission-id=submission.id)= t('quests.contribute.withdraw')
                  else if submission.status === 'approved'
                    button.quest-button.quest-button--secondary(type='button' data-quest-action='revision' data-submission-id=submission.id)= t('quests.contribute.startRevision')

          if mySubmissionTotalPages > 1
            - const contributionSeparator = mySubmissionPaginationBaseUrl.includes('?') ? '&' : '?'
            nav.quest-contribution-pagination(aria-label=t('quests.contribute.pagination.label'))
              if mySubmissionPage > 1
                a.quest-button.quest-button--secondary(href=uiPath(`${mySubmissionPaginationBaseUrl}${contributionSeparator}contributionsPage=${mySubmissionPage - 1}#quest-contributions`))= t('quests.contribute.pagination.previous')
              span= t('quests.contribute.pagination.status', { current: mySubmissionPage, total: mySubmissionTotalPages, count: mySubmissionTotal })
              if mySubmissionPage < mySubmissionTotalPages
                a.quest-button.quest-button--secondary(href=uiPath(`${mySubmissionPaginationBaseUrl}${contributionSeparator}contributionsPage=${mySubmissionPage + 1}#quest-contributions`))= t('quests.contribute.pagination.next')

    nav#quest-sections.quest-tabs(data-quest-tabs aria-label=t('quests.detail.sectionsLabel'))
      if quest.type === 'set'
        a(class=view === 'items' ? 'active' : '' aria-current=view === 'items' ? 'page' : null href=uiPath(`/quests/${quest.slug}?view=items#quest-sections`))= t('quests.detail.tabs.items')
      a(class=view === 'posts' ? 'active' : '' aria-current=view === 'posts' ? 'page' : null href=uiPath(`/quests/${quest.slug}?view=posts#quest-sections`))= t('quests.detail.tabs.posts')
      a(class=view === 'leaderboard' ? 'active' : '' aria-current=view === 'leaderboard' ? 'page' : null href=uiPath(`/quests/${quest.slug}?view=leaderboard#quest-sections`))= t('quests.detail.tabs.leaderboard')

    .quest-tab-panel(data-quest-tab-panel aria-live='polite')
      include _detail_tab_panel
